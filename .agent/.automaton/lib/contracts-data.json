  },
  "prerequisiteDiagnosticCodes": {
    "canonicalSpec": "missing_canonical_spec",
    "canonicalPlan": "missing_canonical_plan"
  },
  "canonicalPointerChecks": [
    { "field": "canonicalSpec", "code": "stale_canonical_spec", "level": "error" },
    { "field": "canonicalPlan", "code": "stale_canonical_plan", "level": "error" },
    { "field": "canonicalDesign", "code": "stale_canonical_design", "level": "warning" }
  ]
