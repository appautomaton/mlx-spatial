{
  "stages": ["frame", "plan", "execute", "verify", "resume"],
  "lenses": ["product", "engineering", "design", "security", "runtime"],
  "artifactLayout": {
    "agentRoot": ".agent",
    "runtimeRoot": ".agent/.automaton",
    "steeringDir": "steering",
    "wikiDir": "wiki",
    "workDir": "work"
  },
  "stagePrerequisites": {
    "frame": [],
